DATABASE_URL="postgresql://usuario:clave@localhost:5432/cocode-system"
JWT_SECRET="cambiar-por-un-secreto-largo"

# URL del frontend (para enlaces en correos)
FRONTEND_URL=http://localhost:5173

# Correo saliente (obligatorio para enviar restablecimiento de contraseña)
# Ejemplo Gmail: crear contraseña de aplicación en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=contraseña_de_aplicacion
SMTP_FROM="COCODE Villas del Quetzal <tu_correo@gmail.com>"
