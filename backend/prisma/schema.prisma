// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoCasa {
  ACTIVA
  VACIA
  ABANDONADA
  ALQUILADA
}

enum TipoPlaca {
  AUTO
  MOTO
}

enum EstadoDeuda {
  PENDIENTE
  PAGADA
}

enum EstadoRecibo {
  ACTIVO
  ANULADO
}

model Rol {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  usuarios Usuario[]
}

model Usuario {
  id Int @id @default(autoincrement())

  nombre   String
  usuario  String @unique
  email    String @unique
  password String

  resetTokenHash    String?
  resetTokenExpires DateTime?

  activo Boolean @default(true)

  ultimoLogin DateTime?

  rolId Int
  rol   Rol @relation(fields: [rolId], references: [id])

  pagos Pago[]

  recibos Recibo[]

  bitacoras Bitacora[]

  createdAt DateTime @default(now())
}

model Bitacora {
  id Int @id @default(autoincrement())

  usuarioId Int

  modulo String
  accion String

  descripcion String

  fecha DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([fecha])
}

model Sector {
  id Int @id @default(autoincrement())

  nombre String @unique

  casas Casa[]
}

model Casa {
  id Int @id @default(autoincrement())

  codigoCasa Int @unique

  manzana String?

  lote String?

  direccion String

  propietarioActual String?

  observaciones String?

  activo Boolean @default(true)

  estado EstadoCasa @default(ACTIVA)

  sectorId Int?
  sector   Sector? @relation(fields: [sectorId], references: [id])

  deudas Deuda[]

  tarifasEspeciales TarifaEspecial[]

  cortesAgua CorteAgua[]

  telefonos TelefonoCasa[]

  placas PlacaCasa[]

  recibos Recibo[]

  createdAt DateTime @default(now())

  @@unique([manzana, lote])
  @@index([codigoCasa])
  @@index([manzana, lote])
}

model TelefonoCasa {
  id Int @id @default(autoincrement())

  casaId Int

  numero String

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([casaId])
}

model PlacaCasa {
  id Int @id @default(autoincrement())

  casaId Int

  placa String

  tipo TipoPlaca

  casa Casa @relation(fields: [casaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([casaId])
  @@index([placa])
}

model Servicio {
  id Int @id @default(autoincrement())

  nombre String @unique

  montoBase Decimal @default(100) @db.Decimal(10, 2)

  deudas Deuda[]

  tarifasEspeciales TarifaEspecial[]

  recibos Recibo[]

  correlativo CorrelativoRecibo?
}

model CorrelativoRecibo {
  id Int @id @default(autoincrement())

  servicioId Int @unique

  prefijo String

  ultimoNumero Int @default(0)

  servicio Servicio @relation(fields: [servicioId], references: [id])
}

model TarifaEspecial {
  id Int @id @default(autoincrement())

  casaId Int

  servicioId Int

  monto Decimal @db.Decimal(10, 2)

  activo Boolean @default(true)

  casa Casa @relation(fields: [casaId], references: [id])

  servicio Servicio @relation(fields: [servicioId], references: [id])

  @@unique([casaId, servicioId])
}

model Deuda {
  id Int @id @default(autoincrement())

  casaId Int

  servicioId Int

  anio Int

  mes Int

  monto Decimal @db.Decimal(10, 2)

  mora Decimal @default(0) @db.Decimal(10, 2)

  estado EstadoDeuda @default(PENDIENTE)

  esExtra Boolean @default(false)

  observaciones String?

  casa Casa @relation(fields: [casaId], references: [id])

  servicio Servicio @relation(fields: [servicioId], references: [id])

  pago Pago[]

  createdAt DateTime @default(now())

  @@unique([casaId, servicioId, anio, mes])
  @@index([anio, mes])
}

model Pago {
  id Int @id @default(autoincrement())

  deudaId Int

  reciboId Int

  usuarioId Int

  fechaPago DateTime @default(now())

  montoDeuda Decimal @db.Decimal(10, 2)

  deuda Deuda @relation(fields: [deudaId], references: [id])

  recibo Recibo @relation(fields: [reciboId], references: [id])

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([fechaPago])
  @@index([deudaId])
  @@index([reciboId])
}

model Recibo {
  id Int @id @default(autoincrement())

  numeroRecibo String @unique

  estado EstadoRecibo @default(ACTIVO)

  motivoAnulacion String?

  observaciones String?

  fechaAnulacion DateTime?

  casaId Int

  servicioId Int

  usuarioId Int

  montoTotal Decimal @db.Decimal(10, 2)

  montoPagado Decimal @db.Decimal(10, 2)

  casa Casa @relation(fields: [casaId], references: [id])

  servicio Servicio @relation(fields: [servicioId], references: [id])

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  pagos Pago[]

  createdAt DateTime @default(now())

  @@index([casaId])
  @@index([servicioId])
  @@index([createdAt])
}

model CorteAgua {
  id Int @id @default(autoincrement())

  casaId Int

  fechaCorte DateTime

  fechaReconexion DateTime?

  observaciones String?

  activo Boolean @default(true)

  casa Casa @relation(fields: [casaId], references: [id])
}

model Configuracion {
  id Int @id @default(autoincrement())

  tarifaAgua Decimal @db.Decimal(10, 2)

  tarifaSeguridad Decimal @db.Decimal(10, 2)

  moraDefecto Decimal @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt
}
